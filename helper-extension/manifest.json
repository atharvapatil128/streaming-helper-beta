{
  "manifest_version": 3,
  "name": "Streaming Helper",
  "description": "Friend recommendations and comfort picks while you stream — Beta 2.",
  "version": "0.3.4",
  "minimum_chrome_version": "102",

  "icons": {
    "16":  "icons/icon-16.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Streaming Helper",
    "default_icon": {
      "16":  "icons/icon-16.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
    }
  },

  "permissions": ["storage"],

  "host_permissions": [
    "https://htqwzovhfyyaaipoovjp.supabase.co/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://*.netflix.com/*",
        "https://*.primevideo.com/*",
        "https://*.disneyplus.com/*",
        "https://*.hulu.com/*",
        "https://max.com/*",
        "https://*.max.com/*",
        "https://hbomax.com/*",
        "https://*.hbomax.com/*"
      ],
      "js": ["content.js", "recommend-detection.js", "recommend.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon.svg",
        "icons/helper-passive.svg",
        "icons/helper-active.svg",
        "icons/recommend-active.png"
      ],
      "matches": [
        "https://*.netflix.com/*",
        "https://*.primevideo.com/*",
        "https://*.disneyplus.com/*",
        "https://*.hulu.com/*",
        "https://max.com/*",
        "https://*.max.com/*",
        "https://hbomax.com/*",
        "https://*.hbomax.com/*"
      ]
    }
  ]
}
