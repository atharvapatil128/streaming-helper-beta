{
  "manifest_version": 3,
  "name": "Streaming Helper",
  "description": "Friend recommendations and comfort picks while you stream — Beta 1.",
  "version": "0.1.0",

  "icons": {
    "16":  "icons/icon.svg",
    "48":  "icons/icon.svg",
    "128": "icons/icon.svg"
  },

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Streaming Helper"
  },

  "permissions": ["storage"],

  "host_permissions": [
    "https://htqwzovhfyyaaipoovjp.supabase.co/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "*://*.netflix.com/*",
        "*://*.primevideo.com/*",
        "*://*.disneyplus.com/*",
        "*://*.hulu.com/*",
        "*://*.max.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon.svg",
        "icons/helper-passive.svg",
        "icons/helper-active.svg"
      ],
      "matches": [
        "*://*.netflix.com/*",
        "*://*.primevideo.com/*",
        "*://*.disneyplus.com/*",
        "*://*.hulu.com/*",
        "*://*.max.com/*"
      ]
    }
  ]
}
